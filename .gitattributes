# 统一以 LF 存储所有文本文件，消除 Windows 上 "LF will be replaced by CRLF" 警告
* text=auto eol=lf

# 显式声明常见文本类型
*.py    text eol=lf
*.md    text eol=lf
*.toml  text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

# 二进制文件不做行尾转换
*.png  binary
*.jpg  binary
*.gif  binary
*.ico  binary
*.pdf  binary
